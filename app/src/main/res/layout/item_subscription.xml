<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <!-- Строка 1: имя + переключатель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/tvSubName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subscription name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSubCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvSubLastUpdate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvSubUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="filename.txt"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:maxLines="1"
                android:ellipsize="start"/>

        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSubEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Строка 2: кнопки действий -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPing"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="📡 Пинг"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubSpeedTest"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="📊 Скорость"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubImport"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="→ v2ray"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubClear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="32dp"
            android:text="🗑 Очистить"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="@color/ping_warn"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubDelete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textColor="@color/error_color"/>

    </LinearLayout>

    <!-- Результат пинга/скорости -->
    <TextView
        android:id="@+id/tvSubPingResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="@color/ping_good"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        android:paddingStart="4dp"/>

</LinearLayout>
